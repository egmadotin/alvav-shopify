

{% liquid
  if section.settings.background_color != blank
    render 'contrast-override', background_color: section.settings.background_color, section_id: section.id
  endif
%}

{% liquid
  assign overlay_alpha = section.settings.overlay_opacity | divided_by: 100.0
%}
<style>
  footer {
    {% if section.settings.background_image != blank %}
      background-image: linear-gradient(rgba(0,0,0,{{ overlay_alpha }}), rgba(0,0,0,{{ overlay_alpha }})), url('{{ section.settings.background_image | img_url: '2000x' }}');
    {% elsif section.settings.background_image_asset != blank %}
      background-image: linear-gradient(rgba(0,0,0,{{ overlay_alpha }}), rgba(0,0,0,{{ overlay_alpha }})), url('{{ section.settings.background_image_asset | asset_url }}');
    {% else %}
      background-image: linear-gradient(rgba(0,0,0,{{ overlay_alpha }}), rgba(0,0,0,{{ overlay_alpha }})), url('{{ 'footerbg.webp' | asset_url }}');
    {% endif %}
    background-position: center calc(100% + 35px);
    background-repeat: no-repeat;
    background-size: cover;
    background-color: {{ section.settings.background_color | default: '#1a261c' }};
    border-top-left-radius: 20px;
    border-top-right-radius: 20px;
  }
  
  /* Social Icons Styling */
  .social-icons__wrapper { display: flex; gap: 15px; margin-top: 25px; justify-content: flex-start; }
  .social-icons__icon-wrapper { width: auto !important; height: auto !important; flex-shrink: 0; }
  .social-icons__wrapper a { display: flex; justify-content: center; align-items: center; width: 42px; height: 42px; min-width: 42px; min-height: 42px; background-color: #fff; color: #1a261c !important; border-radius: 50%; text-decoration: none; }
  .social-icons__wrapper a svg { width: 26px; height: 26px; fill: currentColor; }

  /* Email Signup Styling */
  footer .email-signup__input-group { background-color: #ffffff; border-radius: 50px !important; display: flex; align-items: center; padding: 6px; border: none !important; margin-top: 15px; }
  footer .email-signup__input { background: transparent !important; border: none !important; color: #333 !important; flex: 1; padding-left: 20px; outline: none !important; box-shadow: none !important; font-size: 15px; }
  footer .email-signup__input::placeholder { color: #666; }
  footer .email-signup__button { background-color: #1a261c !important; color: #ffffff !important; border-radius: 50px !important; padding: 12px 35px !important; font-weight: 600; border: none !important; min-height: unset !important; height: auto !important; margin: 0; box-shadow: none !important; text-transform: none; font-size: 16px; }
  footer .email-signup__button::after, footer .email-signup__button::before { display: none !important; }

  /* Uniform Footer Typography */
  footer .menu__heading, footer .menu__heading * , footer .custom-menu h3, footer .contact-us-col h3, footer h3 {
    font-size: 18px !important;
    font-weight: 700 !important;
    color: #ffffff !important;
    margin-top: 0 !important;
    margin-bottom: 20px !important;
    line-height: 1.2 !important;
    border: none !important;
    padding: 0 !important;
    background: transparent !important;
  }
  footer .menu__heading__toggle { display: none !important; }
  
  footer .menu__item a, footer .custom-menu a, footer .contact-us-col p, footer p {
    font-size: 14px !important;
    color: #ffffff !important;
    opacity: 0.9 !important;
    margin-bottom: 12px !important;
    text-decoration: none !important;
    display: block;
    line-height: 1.5;
  }
  footer .footer-content a { text-decoration: none !important; }
  footer .contact-us-col p { display: flex !important; align-items: center; }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const footerInput = document.querySelector('footer .email-signup__input');
    if (footerInput) footerInput.placeholder = "Enter your email...";
    const footerBtn = document.querySelector('footer .email-signup__button');
    if (footerBtn) footerBtn.innerHTML = "Submit";
  });
</script>
<div
  class="section-background{% if section.settings.background_color != blank %} color-custom-{{ section.id }}{% endif %}"
></div>
<div
  class="section section--{{ section.settings.section_width }}{% if section.settings.background_color != blank %} color-custom-{{ section.id }}{% endif %}"
>
  {% liquid
    assign total_blocks = section.blocks.size

    # Grid layout calculations
    assign grid_columns = total_blocks | at_most: 4

    # Calculate last row counts using modulo arithmetic
    # last_row_count = (total_blocks - 1) % N + 1
    assign last_row_count = total_blocks | minus: 1 | modulo: 4 | plus: 1
    assign tablet_last_row_count = total_blocks | minus: 1 | modulo: 2 | plus: 1

    # Check if there are orphaned elements (single item in last row)
    assign has_isolated_grid_item_desktop = false
    assign has_isolated_grid_item_tablet = false

    if total_blocks > 4 and last_row_count == 1
      assign has_isolated_grid_item_desktop = true
    endif

    if total_blocks == 5
      assign has_isolated_grid_item_tablet = true
    endif
  %}
  <div
    class="
      footer-content
      spacing-style
      {% if has_isolated_grid_item_desktop %}footer-content--isolated-grid-item-desktop{% endif %}
      {% if has_isolated_grid_item_tablet %}footer-content--isolated-grid-item-tablet{% endif %}
    "
    style="
      {%  render 'spacing-style', settings: section.settings %}
      --footer-gap: {{ section.settings.gap }}px;
      --grid-columns: {{ grid_columns }};
      --last-row-count: {{ last_row_count }};
      --tablet-last-row-count: {{ tablet_last_row_count }};
    "
  >
    {% content_for 'blocks' %}
  </div>
</div>

{% stylesheet %}
  .footer-content {
    contain: content;
    content-visibility: auto;
    display: grid;
    grid-template-columns: 1fr;
    gap: var(--footer-gap);
    align-items: start;
  }

  .footer-content .menu__heading__default {
    font-weight: var(--font-heading--weight);
  }

  @media screen and (min-width: 750px) and (max-width: 989px) {
    .footer-content {
      grid-template-columns: repeat(min(var(--grid-columns), 3), 1fr);
      grid-auto-flow: row;
    }

    .footer-content[style*='--grid-columns: 4'] {
      grid-template-columns: repeat(2, 1fr);
    }

    .footer-content--isolated-grid-item-tablet > :last-child {
      grid-column: 1 / -1;
    }
  }

  @media screen and (min-width: 990px) {
    .footer-content {
      grid-template-columns: repeat(var(--grid-columns), 1fr);
    }

    /* Single item centered */
    .footer-content[style*='--grid-columns: 1'] {
      justify-items: center;
    }

    .footer-content--isolated-grid-item-desktop > :last-child {
      grid-column: 1 / -1;
    }
  }
{% endstylesheet %}

{% schema %}
{
  "name": "t:names.footer",
  "class": "section-wrapper",
  "blocks": [
    {
      "type": "_divider"
    },
    {
      "type": "@app"
    },
    {
      "type": "button"
    },
    {
      "type": "follow-on-shop"
    },
    {
      "type": "group"
    },
    {
      "type": "icon"
    },
    {
      "type": "image"
    },
    {
      "type": "menu"
    },
    {
      "type": "payment-icons"
    },
    {
      "type": "text"
    },
    {
      "type": "logo"
    },
    {
      "type": "jumbo-text"
    },
    {
      "type": "social-links"
    },
    {
      "type": "email-signup"
    },
    {
      "type": "custom-liquid"
    }
  ],
  "enabled_on": {
    "groups": ["footer"]
  },
  "settings": [
    {
      "type": "select",
      "id": "section_width",
      "label": "t:settings.width",
      "options": [
        {
          "value": "page-width",
          "label": "t:options.page"
        },
        {
          "value": "full-width",
          "label": "t:options.full"
        }
      ],
      "default": "page-width"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "t:settings.gap",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "t:settings.background_color",
      "default": "{{ settings.color_palette.foreground }}"
    },
    {
      "type": "header",
      "content": "Background Image"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image (Upload)",
      "info": "Upload a custom footer background image. Overrides the default."
    },
    {
      "type": "text",
      "id": "background_image_asset",
      "label": "Background Image Asset Filename",
      "info": "Enter asset filename (e.g. footerbg.webp) if not uploading above.",
      "placeholder": "footerbg.webp"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Dark Overlay Opacity",
      "info": "Controls how dark the overlay is on the background image.",
      "min": 0,
      "max": 80,
      "step": 5,
      "unit": "%",
      "default": 30
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "t:names.footer",
      "category": "t:categories.footer",
      "settings": {
        "gap": 20,
        "padding-block-start": 36,
        "padding-block-end": 36
      },
      "blocks": {
        "newsletter-group": {
          "type": "group",
          "settings": {
            "content_direction": "column",
            "vertical_on_mobile": true,
            "horizontal_alignment": "flex-start",
            "vertical_alignment": "center",
            "gap": 6,
            "width": "fill"
          },
          "blocks": {
            "newsletter-heading": {
              "type": "text",
              "settings": {
                "text": "t:html_defaults.join_our_email_list",
                "width": "100%",
                "alignment": "left",
                "type_preset": "h3"
              }
            },
            "newsletter-text": {
              "type": "text",
              "settings": {
                "text": "t:html_defaults.get_exclusive_deals_and_early_access_to_new_products",
                "width": "100%",
                "alignment": "left",
                "type_preset": "rte"
              }
            }
          },
          "block_order": ["newsletter-heading", "newsletter-text"]
        },
        "newsletter-form": {
          "type": "email-signup",
          "settings": {
            "width": "fill"
          }
        }
      },
      "block_order": ["newsletter-group", "newsletter-form"]
    }
  ]
}
{% endschema %}
