{% stylesheet %}
  .home-banner-section {
    padding: 20px 0;
    background-color: #f4eee8;
  }
  .home-banner-section .page-width {
    max-width: 1600px;
    margin: 0 auto;
    padding: 0 60px;
  }
  .home-banner-image {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }
  .home-banner-mobile {
    display: none;
    width: 100%;
    height: auto;
  }
  @media (max-width: 768px) {
    .home-banner-section { padding: 0; }
    .home-banner-section .page-width { padding: 0; }
    .home-banner-image { display: none; }
    .home-banner-mobile { display: block; }
  }
{% endstylesheet %}

<div class="home-banner-section">
  <div class="page-width">
    {% assign link_url = section.settings.link | default: '#' %}
    <a href="{{ link_url }}" class="home-banner-link" style="display: block; text-decoration: none;">
      {% if section.settings.image != blank %}
        {{ section.settings.image | image_url: width: 2000 | image_tag: class: 'home-banner-image', loading: 'lazy' }}
      {% else %}
        <img src="{{ 'home_decore_banner.jpg' | asset_url }}" alt="Home Decor Banner" class="home-banner-image">
      {% endif %}
      <!-- Mobile-only banner -->
      <img src="{{ 'mobile-home-decore.png' | asset_url }}" alt="Home Decor Mobile Banner" class="home-banner-mobile">
    </a>
  </div>
</div>

{% schema %}
{
  "name": "Home Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Banner Image"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Banner Link"
    }
  ],
  "presets": [
    {
      "name": "Home Banner"
    }
  ]
}
{% endschema %}
