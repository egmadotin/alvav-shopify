{% stylesheet %}
  .dc-section {
    padding: 60px 0;
    background-color: #f7f9f4; /* light greenish-white bg */
  }
  .dc-container {
    max-width: 1600px;
    margin: 0 auto;
    padding: 0 60px;
  }
  .dc-header {
    text-align: center;
    margin-bottom: 40px;
  }
  .dc-title {
    font-size: 28px;
    font-weight: 700;
    color: #111;
    margin: 0;
  }
  .dc-grid {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
    gap: 30px;
    padding-bottom: 10px;
  }
  .dc-grid::-webkit-scrollbar { display: none; }
  
  /* Spacers only shown on mobile full-bleed scroll */
  .dc-grid::before,
  .dc-grid::after {
    display: none;
  }
  
  .dc-card {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    text-decoration: none;
    display: block;
    aspect-ratio: 4 / 5;
    background: #f0f0f0;
    flex: 0 0 calc(33.333% - 20px);
    scroll-snap-align: start;
    min-width: 0;
  }
  .dc-card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }
  .dc-card:hover .dc-card-image {
    transform: scale(1.05);
  }
  .dc-content {
    position: absolute;
    top: 30px;
    left: 0;
    width: 100%;
    text-align: center;
    padding: 0 20px;
    z-index: 2;
  }
  .dc-card-title {
    font-size: 26px;
    font-weight: 700;
    margin: 0 0 8px 0;
  }
  .dc-card-subtitle {
    font-size: 14px;
    font-weight: 500;
    margin: 0;
  }
  @media (max-width: 1200px) {
    .dc-container { padding: 0 40px; }
  }
  @media (max-width: 990px) {
    .dc-container { padding: 0 20px; }
    .dc-card { flex: 0 0 calc(50% - 15px); }
  }
  @media (max-width: 768px) {
    .dc-section { padding: 30px 0; }
    .dc-container { padding: 0 16px; }
    .dc-header { padding: 0; margin-bottom: 20px; }
    .dc-grid {
      gap: 12px;
    }
    .dc-grid::before,
    .dc-grid::after {
      display: none;
    }
    .dc-card {
      flex: 0 0 calc(60vw);
      aspect-ratio: 3 / 4;
    }
    .dc-card-title { font-size: 20px; }
    .dc-card-subtitle { font-size: 12px; }
  }
{% endstylesheet %}

<div class="dc-section">
  <div class="dc-container">
    <div class="dc-header">
      <h2 class="dc-title">{{ section.settings.title }}</h2>
    </div>
    
    <div class="dc-grid">
      {% for block in section.blocks %}
        <a href="{{ block.settings.link | default: '#' }}" class="dc-card" {{ block.shopify_attributes }}>
          {% if block.settings.image != blank %}
            {{ block.settings.image | image_url: width: 800 | image_tag: class: 'dc-card-image', loading: 'lazy' }}
          {% else %}
            {% capture fallback_image %}
              {% case forloop.index %}
                {% when 1 %}{{ '1_44087a36-3aad-4df0-bda1-70fb0004729f.png' | asset_url }}
                {% when 2 %}{{ '3_67e80761-a97c-4c66-8586-35dfa4f10371.png' | asset_url }}
                {% when 3 %}{{ '4_cd784d75-08b2-4baf-ab52-07953d374d29.png' | asset_url }}
              {% endcase %}
            {% endcapture %}
            <img src="{{ fallback_image | strip }}" class="dc-card-image" alt="{{ block.settings.title }}">
          {% endif %}
        </a>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Designer Chairs",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Designer Chairs"
    }
  ],
  "blocks": [
    {
      "type": "chair_card",
      "name": "Chair Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Background Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Accent Chairs"
        },
        {
          "type": "color",
          "id": "title_color",
          "label": "Title Color",
          "default": "#135c49"
        },
        {
          "type": "text",
          "id": "subtitle",
          "label": "Subtitle",
          "default": "Make Your Room Look Amazing"
        },
        {
          "type": "color",
          "id": "subtitle_color",
          "label": "Subtitle Color",
          "default": "#405b53"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Card Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Designer Chairs",
      "blocks": [
        {
          "type": "chair_card",
          "settings": {
            "title": "Accent Chairs",
            "title_color": "#135c49",
            "subtitle": "Make Your Room Look Amazing",
            "subtitle_color": "#405b53"
          }
        },
        {
          "type": "chair_card",
          "settings": {
            "title": "Ottoman",
            "title_color": "#6e3f3b",
            "subtitle": "Soft, Stylish & Super Functional!",
            "subtitle_color": "#754f4b"
          }
        },
        {
          "type": "chair_card",
          "settings": {
            "title": "Lounge Chairs",
            "title_color": "#2c2c2c",
            "subtitle": "Relax, recline, refresh",
            "subtitle_color": "#444444"
          }
        }
      ]
    }
  ]
}
{% endschema %}
