{% stylesheet %}
  .footer-trust-banner {
    background-color: #555e4e;
    color: #ffffff;
    padding: 30px 20px;
    border-bottom: 1px solid rgba(255,255,255,0.1);
    border-top-left-radius: 20px;
    border-top-right-radius: 20px;
  }
  
  .footer-trust-banner__inner {
    max-width: var(--page-width);
    margin: 0 auto;
    padding: 0 40px;
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 20px;
    align-items: center;
  }
  
  @media screen and (min-width: 750px) {
    .footer-trust-banner__inner {
      grid-template-columns: repeat(4, 1fr);
      gap: 30px;
    }
  }

  .trust-item {
    display: flex;
    align-items: center;
    gap: 15px;
  }
  
  .trust-item__icon {
    flex-shrink: 0;
    width: 65px;
    height: 65px;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  
  .trust-item__icon img {
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    filter: brightness(0) invert(1);
  }
  
  .trust-item__icon svg {
    width: 40px;
    height: 40px;
    color: #fff;
  }

  .trust-item__text h4 {
    margin: 0 0 5px 0;
    font-size: 1.1rem;
    font-weight: 600;
    color: #ffffff;
    line-height: 1.2;
  }
  
  .trust-item__text p {
    margin: 0;
    font-size: 0.85rem;
    color: #e0e0e0;
    line-height: 1.3;
  }
{% endstylesheet %}

<div class="footer-trust-banner" data-section-id="{{ section.id }}">
  <div class="footer-trust-banner__inner">
    
    <div class="trust-item">
      <div class="trust-item__icon">
        <img src="{{ 'hand-shake.png' | asset_url }}" alt="Trusted" loading="lazy" width="65" height="65">
      </div>
      <div class="trust-item__text">
        <h4>Trusted By 700000+</h4>
        <p>Customers</p>
      </div>
    </div>
    
    <div class="trust-item">
      <div class="trust-item__icon">
        <img src="{{ 'car.png' | asset_url }}" alt="Next Day Dispatch" loading="lazy" width="65" height="65">
      </div>
      <div class="trust-item__text">
        <h4>Next Day Dispatch</h4>
        <p>Fast shipping all over india</p>
      </div>
    </div>
    
    <div class="trust-item">
      <div class="trust-item__icon">
        <img src="{{ 'wheel.png' | asset_url }}" alt="Unique Designs" loading="lazy" width="65" height="65">
      </div>
      <div class="trust-item__text">
        <h4>Unique Designs</h4>
        <p>World class Quality and Design experience</p>
      </div>
    </div>
    
    <div class="trust-item">
      <div class="trust-item__icon">
        <img src="{{ 'rupee.png' | asset_url }}" alt="Secure Payment" loading="lazy" width="65" height="65">
      </div>
      <div class="trust-item__text">
        <h4>100% Secure Payment</h4>
        <p>Trusted & Secure Payment</p>
      </div>
    </div>
    
  </div>
</div>

{% schema %}
{
  "name": "Footer Trust Banner",
  "settings": [],
  "presets": [
    {
      "name": "Footer Trust Banner"
    }
  ]
}
{% endschema %}
