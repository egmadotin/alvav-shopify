{% stylesheet %}
  .pm-section {
    padding: 60px 0;
    background-color: #f2f4e8; /* matches screenshot light greenish bg */
  }
  .pm-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
  }
  .pm-header {
    text-align: center;
    margin-bottom: 40px;
  }
  .pm-title {
    font-size: 24px;
    font-weight: 700;
    color: #111;
    margin: 0;
  }
  .pm-grid {
    display: flex;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    -ms-overflow-style: none;
    gap: 30px;
    padding-bottom: 10px;
  }
  .pm-grid::-webkit-scrollbar { display: none; }
  
  /* Spacers only shown on mobile full-bleed scroll */
  .pm-grid::before,
  .pm-grid::after {
    display: none;
  }

  .pm-card {
    position: relative;
    border-radius: 4px;
    overflow: hidden;
    text-decoration: none;
    display: block;
    flex: 0 0 calc(33.333% - 20px);
    scroll-snap-align: start;
    min-width: 0;
  }
  .pm-card-inner {
    width: 100%;
    height: 100%;
    position: relative;
    overflow: hidden;
  }
  .pm-card-image {
    width: 100%;
    height: auto;
    display: block;
  }
  @media (max-width: 990px) {
    .pm-container { padding: 0 20px; }
    .pm-card { flex: 0 0 calc(50% - 15px); }
  }
  @media (max-width: 768px) {
    .pm-section { padding: 30px 0; }
    .pm-container { padding: 0 16px; }
    .pm-header { padding: 0; margin-bottom: 20px; }
    .pm-grid {
      gap: 12px;
    }
    .pm-grid::before,
    .pm-grid::after {
      display: none;
    }
    .pm-card {
      flex: 0 0 calc(60vw);
    }
  }
{% endstylesheet %}

<div class="pm-section">
  <div class="pm-container">
    <div class="pm-header">
      <h2 class="pm-title">{{ section.settings.title }}</h2>
    </div>
    
    <div class="pm-grid">
      {% for block in section.blocks %}
        <a href="{{ block.settings.link | default: '#' }}" class="pm-card" {{ block.shopify_attributes }}>
          <div class="pm-card-inner">
            {% if block.settings.image != blank %}
              {{ block.settings.image | image_url: width: 800 | image_tag: class: 'pm-card-image', loading: 'lazy' }}
            {% else %}
              {% capture fallback_image %}
                {% case forloop.index %}
                  {% when 1 %}{{ 'lm1.jpg' | asset_url }}
                  {% when 2 %}{{ 'lm2.jpg' | asset_url }}
                  {% when 3 %}{{ 'lm3.jpg' | asset_url }}
                {% endcase %}
              {% endcapture %}
              <img src="{{ fallback_image | strip }}" class="pm-card-image" alt="Premium Mirror">
            {% endif %}
          </div>
        </a>
      {% endfor %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Premium Mirrors",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Premium Mirrors"
    }
  ],
  "blocks": [
    {
      "type": "mirror",
      "name": "Mirror Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Mirror Image"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Card Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Premium Mirrors",
      "blocks": [
        { "type": "mirror" },
        { "type": "mirror" },
        { "type": "mirror" }
      ]
    }
  ]
}
{% endschema %}
