<style>
  .collection-hero-banner {
    position: relative;
    width: 100%;
    height: 0;
    padding-bottom: 27%; /* Aspect ratio of ~21:9, adjust as needed */
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    box-sizing: border-box;
    overflow: hidden;
    border-radius: var(--collection-hero-banner-radius, 0);
  }

  @media (max-width: 768px) {
    .collection-hero-banner {
      padding-bottom: 45%; /* Taller on mobile for better view */
    }
  }

  .collection-hero-banner-wrapper {
    padding-inline: 16px;
  }

  @media screen and (min-width: 750px) {
    .collection-hero-banner-wrapper {
      padding-inline: 40px;
    }
  }
</style>

{% liquid
  assign bg_image = section.settings.image
  if bg_image == blank
    assign bg_image_url = 'mirror_banner.webp' | asset_url
  else
    assign bg_image_url = bg_image | image_url: width: 2000
  endif
%}

{% if section.settings.add_side_padding %}
  <div class="collection-hero-banner-wrapper">
    <div
      class="collection-hero-banner"
      style="background-image: url('{{ bg_image_url }}'); --collection-hero-banner-radius: 12px;"
    ></div>
  </div>
{% else %}
  <div class="collection-hero-banner" style="background-image: url('{{ bg_image_url }}');"></div>
{% endif %}

{% schema %}
{
  "name": "Collection Hero Banner",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image",
      "info": "Defaults to mirror_banner.webp if empty"
    },
    {
      "type": "checkbox",
      "id": "add_side_padding",
      "label": "Add left/right page margin",
      "default": false,
      "info": "When off, the banner spans edge-to-edge."
    }
  ],
  "presets": [
    {
      "name": "Collection Hero Banner"
    }
  ]
}
{% endschema %}
