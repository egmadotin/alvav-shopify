            "custom_liquid": "<style>.custom-payment-icons { display: flex; align-items: center; gap: 8px; font-size: 14px; color: rgba(255,255,255,0.7); flex-wrap: wrap; } .custom-payment-icons span { margin-right: 8px; } .custom-payment-icons img { height: 32px; width: auto; object-fit: contain; background: #fff; padding: 4px 8px; border-radius: 6px; }</style><div class=\"custom-payment-icons\"><span>We accept</span> <img src=\"{{ 'paytm.webp' | asset_url }}\" alt=\"Paytm\"> <img src=\"{{ 'phone-pay.webp' | asset_url }}\" alt=\"PhonePe\"> <img src=\"{{ 'upi.webp' | asset_url }}\" alt=\"UPI\"> <img src=\"{{ 'gpay.webp' | asset_url }}\" alt=\"GPay\"> <img src=\"{{ 'rupay.webp' | asset_url }}\" alt=\"RuPay\"> <img src=\"{{ 'visa.webp' | asset_url }}\" alt=\"VISA\"></div>"
