{% stylesheet %}
  .promo-banner-2-section {
    padding: 0;
    background-color: #ffffff;
  }
  .promo-banner-2-section .page-width {
    max-width: 1600px;
    margin: 0 auto;
    padding: 20px 60px;
  }
  .promo-banner-2-image {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }
  @media (max-width: 990px) {
    .promo-banner-2-section .page-width { padding: 10px 20px; }
  }
{% endstylesheet %}

<div class="promo-banner-2-section">
  <div class="page-width">
    {% assign link_url = section.settings.link | default: '#' %}
    <a href="{{ link_url }}" class="promo-banner-2-link" style="display: block; text-decoration: none;">
      <picture>
        {%- if section.settings.image_mobile != blank -%}
          <source media="(max-width: 768px)" srcset="{{ section.settings.image_mobile | image_url: width: 1000 }}">
        {%- else -%}
          <source media="(max-width: 768px)" srcset="{{ '1_73933ae6-0490-4b06-8a83-c08f14156fd1.jpg' | asset_url }}">
        {%- endif -%}

        {%- if section.settings.image != blank -%}
          <img src="{{ section.settings.image | image_url: width: 2000 }}" alt="Promo Banner" class="promo-banner-2-image" loading="lazy">
        {%- else -%}
          <img src="{{ 'mirror_banner.webp' | asset_url }}" alt="Promo Banner" class="promo-banner-2-image" loading="lazy">
        {%- endif -%}
      </picture>
    </a>
  </div>
</div>

{% schema %}
{
  "name": "Promo Banner 2",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Desktop Banner Image"
    },
    {
      "type": "image_picker",
      "id": "image_mobile",
      "label": "Mobile Banner Image"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Banner Link"
    }
  ],
  "presets": [
    {
      "name": "Promo Banner 2"
    }
  ]
}
{% endschema %}
