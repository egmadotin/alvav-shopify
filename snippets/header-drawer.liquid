      width: 100%;
      height: 100%;
      object-fit: cover;
    }
  }

  .custom-category-drawer__grid-title {
    font-size: 9.5px;
    color: #333333;
    font-weight: 500;
    line-height: 1.2;
    display: -webkit-box;
    -webkit-line-clamp: 2;
