  .custom-category-drawer__empty {
    grid-column: span 3;
    font-size: 11px;
    color: #888888;
    text-align: center;
    margin-block: 8px;
  }

  .custom-category-drawer__footer {
    background-color: #708A6F;
    padding-block: 14px;
    padding-inline: 16px;
    display: flex;
    justify-content: space-around;
    align-items: center;
    border-top: 1px solid rgba(255, 255, 255, 0.1);
  }

  .custom-category-drawer__footer-link {
    display: flex;
    align-items: center;
    gap: 8px;
    color: #ffffff;
    text-decoration: none;
    font-size: 12px;
    font-weight: 500;
    font-family: var(--font-body--family);

    .footer-icon {
      width: 18px;
      height: 18px;
      object-fit: contain;
      filter: brightness(0) invert(1); /* makes the icon white */
    }
  }

  /* Make details panel take full screen and cover the top header */
  .menu-drawer-container[open] .menu-drawer {
    display: flex;
    flex-direction: column;
    position: fixed !important;
    top: 0 !important;
    left: 0 !important;
    height: 100vh !important;
    height: 100dvh !important;
    width: 100vw !important;
    max-width: 100vw !important;
    z-index: 99999 !important;
  }
{% endstyle %}
