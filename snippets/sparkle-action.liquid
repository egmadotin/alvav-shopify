{%- doc -%}
  Renders the sparkle/highlights action button, shown before the search icon.

  @example
  {% render 'sparkle-action' %}
{%- enddoc -%}

<a
  href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
  class="header-actions__action header-actions__action--sparkle"
  aria-label="{%- if customer -%}Account{%- else -%}{{ 'accessibility.log_in' | t }}{%- endif -%}"
>
  <img
    src="{{ 'icon-sparkle-person.png' | asset_url }}"
    class="header-actions__action--sparkle-image"
    width="22"
    height="22"
    loading="lazy"
    alt=""
    aria-hidden="true"
  >
</a>

<style>
  .header-actions__action--sparkle {
    margin-left: 20px;
    display: inline-flex;
    align-items: center;
  }
  
  .header-actions__action--sparkle-image {
    width: 25px !important;
    height: 25px !important;
    object-fit: contain;
    display: block;
  }

  @media screen and (max-width: 768px) {
    .header-actions__action--sparkle {
      display: none !important;
    }
  }
</style>
