{% doc %}
  @prompt
    add recently vwied carousal
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{%- liquid
  assign fallback_collection = block.settings.fallback_collection
  if fallback_collection == blank
    assign fallback_collection = product.collections.first
  endif
-%}

{% capture fallback_products_json %}
[
  {%- assign fallback_collected = 0 -%}
  {%- for fallback_product in fallback_collection.products limit: 12 -%}
    {%- if fallback_product.id != product.id and fallback_collected < 4 -%}
      {%- unless fallback_collected == 0 -%},{%- endunless -%}
      {
        "title": {{ fallback_product.title | json }},
        "url": {{ fallback_product.url | json }},
        "price": {{ fallback_product.price | default: 0 }},
        "featured_image": {{ fallback_product.featured_image | image_url: width: 600 | json }}
      }
      {%- assign fallback_collected = fallback_collected | plus: 1 -%}
    {%- endif -%}
  {%- endfor -%}
]
{% endcapture %}

{% style %}
  .ai-recently-viewed-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.section_padding }}px 0;
    background-color: {{ block.settings.background_color }};
  }

  .ai-recently-viewed-container-{{ ai_gen_id }} {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-recently-viewed-header-{{ ai_gen_id }} {
    margin-bottom: 32px;
    text-align: {{ block.settings.heading_alignment }};
  }

  .ai-recently-viewed-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.heading_size }}px;
    color: {{ block.settings.heading_color }};
    margin: 0;
  }

  .ai-recently-viewed-carousel-wrapper-{{ ai_gen_id }} {
    position: relative;
  }

  .ai-recently-viewed-carousel-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.gap }}px;
    overflow-x: auto;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
    padding-bottom: 10px;
  }

  .ai-recently-viewed-carousel-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  .ai-recently-viewed-product-{{ ai_gen_id }} {
    flex: 0 0 calc((100% - ({{ block.settings.products_per_row_desktop | minus: 1 }} * {{ block.settings.gap }}px)) / {{ block.settings.products_per_row_desktop }});
    min-width: 200px;
  }

  .ai-recently-viewed-card-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    height: 100%;
    text-decoration: none;
    color: inherit;
    border-radius: {{ block.settings.card_border_radius }}px;
    overflow: hidden;
    background-color: {{ block.settings.card_background }};
    transition: transform 0.3s ease;
  }

  .ai-recently-viewed-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
  }

  .ai-recently-viewed-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    padding-bottom: 100%;
    overflow: hidden;
    background-color: #f5f5f5;
  }

  .ai-recently-viewed-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-recently-viewed-info-{{ ai_gen_id }} {
    padding: 16px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .ai-recently-viewed-product-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.product_title_size }}px;
    color: {{ block.settings.product_title_color }};
    margin: 0;
    line-height: 1.4;
  }

  .ai-recently-viewed-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    color: {{ block.settings.price_color }};
    font-weight: 600;
  }

  .ai-recently-viewed-nav-{{ ai_gen_id }} {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background-color: {{ block.settings.nav_button_background }};
    color: {{ block.settings.nav_button_color }};
    border: none;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2;
    transition: opacity 0.3s ease;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .ai-recently-viewed-nav-{{ ai_gen_id }}:hover {
    opacity: 0.8;
  }

  .ai-recently-viewed-nav-{{ ai_gen_id }}:disabled {
    opacity: 0.3;
    cursor: not-allowed;
  }

  .ai-recently-viewed-nav-prev-{{ ai_gen_id }} {
    left: -20px;
  }

  .ai-recently-viewed-nav-next-{{ ai_gen_id }} {
    right: -20px;
  }

  .ai-recently-viewed-empty-{{ ai_gen_id }} {
    text-align: center;
    padding: 60px 20px;
    color: #999;
    font-size: 16px;
  }

  @media screen and (max-width: 749px) {
    .ai-recently-viewed-product-{{ ai_gen_id }} {
      flex: 0 0 calc((100% - ({{ block.settings.products_per_row_mobile | minus: 1 }} * {{ block.settings.gap }}px)) / {{ block.settings.products_per_row_mobile }});
    }

    .ai-recently-viewed-nav-{{ ai_gen_id }} {
      display: none;
    }

    .ai-recently-viewed-title-{{ ai_gen_id }} {
      font-size: calc({{ block.settings.heading_size }}px * 0.7);
    }
  }
{% endstyle %}

<recently-viewed-carousel-{{ ai_gen_id }}
  class="ai-recently-viewed-{{ ai_gen_id }}"
  data-product-id="{{ product.id }}"
  data-max-products="{{ block.settings.max_products }}"
  data-fallback-products="{{ fallback_products_json | strip_newlines | escape }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-recently-viewed-container-{{ ai_gen_id }}">
    <div class="ai-recently-viewed-header-{{ ai_gen_id }}">
      <h2 class="ai-recently-viewed-title-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
    </div>

    <div class="ai-recently-viewed-carousel-wrapper-{{ ai_gen_id }}">
      <button
        class="ai-recently-viewed-nav-{{ ai_gen_id }} ai-recently-viewed-nav-prev-{{ ai_gen_id }}"
        aria-label="Previous products"
        disabled
      >
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M12.5 15L7.5 10L12.5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>

      <div class="ai-recently-viewed-carousel-{{ ai_gen_id }}">
      </div>

      <button
        class="ai-recently-viewed-nav-{{ ai_gen_id }} ai-recently-viewed-nav-next-{{ ai_gen_id }}"
        aria-label="Next products"
      >
        <svg width="20" height="20" viewBox="0 0 20 20" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M7.5 15L12.5 10L7.5 5" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
        </svg>
      </button>
    </div>
  </div>
</recently-viewed-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class RecentlyViewedCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.carousel = this.querySelector('.ai-recently-viewed-carousel-{{ ai_gen_id }}');
        this.prevButton = this.querySelector('.ai-recently-viewed-nav-prev-{{ ai_gen_id }}');
        this.nextButton = this.querySelector('.ai-recently-viewed-nav-next-{{ ai_gen_id }}');
        this.currentProductId = this.dataset.productId;
        this.maxProducts = parseInt(this.dataset.maxProducts);
        this.storageKey = 'recently_viewed_products';
        try {
          this.fallbackProducts = JSON.parse(this.dataset.fallbackProducts || '[]');
        } catch (e) {
          this.fallbackProducts = [];
        }
      }

      connectedCallback() {
        this.saveCurrentProduct();
        this.loadRecentlyViewed();
        this.setupNavigation();
      }

      saveCurrentProduct() {
        if (!this.currentProductId) return;

        let recentProducts = this.getRecentProducts();
        recentProducts = recentProducts.filter(id => id !== this.currentProductId);
        recentProducts.unshift(this.currentProductId);
        recentProducts = recentProducts.slice(0, this.maxProducts);

        try {
          localStorage.setItem(this.storageKey, JSON.stringify(recentProducts));
        } catch (e) {
          console.error('Failed to save to localStorage:', e);
        }
      }

      getRecentProducts() {
        try {
          const stored = localStorage.getItem(this.storageKey);
          return stored ? JSON.parse(stored) : [];
        } catch (e) {
          console.error('Failed to read from localStorage:', e);
          return [];
        }
      }

      async loadRecentlyViewed() {
        let recentProducts = this.getRecentProducts();
        recentProducts = recentProducts.filter(id => id !== this.currentProductId);

        if (recentProducts.length === 0) {
          this.renderFallbackProducts();
          return;
        }

        const productPromises = recentProducts.map(id => this.fetchProduct(id));
        const products = await Promise.all(productPromises);
        const validProducts = products.filter(p => p !== null);

        if (validProducts.length === 0) {
          this.renderFallbackProducts();
          return;
        }

        this.renderProducts(validProducts);
      }

      renderFallbackProducts() {
        if (!this.fallbackProducts || this.fallbackProducts.length === 0) {
          this.showEmptyState();
          return;
        }

        this.renderProducts(this.fallbackProducts);
      }

      async fetchProduct(productId) {
        try {
          const response = await fetch(`/products/${productId}.js`);
          if (!response.ok) return null;
          return await response.json();
        } catch (e) {
          console.error('Failed to fetch product:', e);
          return null;
        }
      }

      renderProducts(products) {
        this.carousel.innerHTML = products.map(product => {
          const price = this.formatMoney(product.price);
          const imageUrl = product.featured_image || '';

          return `
            <div class="ai-recently-viewed-product-{{ ai_gen_id }}">
              <a href="${product.url}" class="ai-recently-viewed-card-{{ ai_gen_id }}">
                <div class="ai-recently-viewed-image-wrapper-{{ ai_gen_id }}">
                  ${imageUrl ? `<img src="${imageUrl}" alt="${this.escapeHtml(product.title)}" class="ai-recently-viewed-image-{{ ai_gen_id }}" loading="lazy">` : ''}
                </div>
                <div class="ai-recently-viewed-info-{{ ai_gen_id }}">
                  <h3 class="ai-recently-viewed-product-title-{{ ai_gen_id }}">${this.escapeHtml(product.title)}</h3>
                  <div class="ai-recently-viewed-price-{{ ai_gen_id }}">${price}</div>
                </div>
              </a>
            </div>
          `;
        }).join('');

        this.updateNavigationState();
      }

      showEmptyState() {
        this.carousel.innerHTML = `
          <div class="ai-recently-viewed-empty-{{ ai_gen_id }}">
            No recently viewed products yet
          </div>
        `;
        if (this.prevButton) this.prevButton.style.display = 'none';
        if (this.nextButton) this.nextButton.style.display = 'none';
      }

      setupNavigation() {
        if (this.prevButton) {
          this.prevButton.addEventListener('click', () => {
            const scrollAmount = this.carousel.offsetWidth * 0.8;
            this.carousel.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
          });
        }

        if (this.nextButton) {
          this.nextButton.addEventListener('click', () => {
            const scrollAmount = this.carousel.offsetWidth * 0.8;
            this.carousel.scrollBy({ left: scrollAmount, behavior: 'smooth' });
          });
        }

        if (this.carousel) {
          this.carousel.addEventListener('scroll', () => {
            this.updateNavigationState();
          });
        }
      }

      updateNavigationState() {
        if (!this.carousel || !this.prevButton || !this.nextButton) return;

        const isAtStart = this.carousel.scrollLeft <= 0;
        const isAtEnd = this.carousel.scrollLeft + this.carousel.offsetWidth >= this.carousel.scrollWidth - 1;

        this.prevButton.disabled = isAtStart;
        this.nextButton.disabled = isAtEnd;
      }

      formatMoney(cents) {
        const amount = cents / 100;
        return new Intl.NumberFormat('en-IN', {
          style: 'currency',
          currency: 'INR'
        }).format(amount);
      }

      escapeHtml(text) {
        const div = document.createElement('div');
        div.textContent = text;
        return div.innerHTML;
      }
    }

    customElements.define('recently-viewed-carousel-{{ ai_gen_id }}', RecentlyViewedCarousel{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Recently viewed carousel",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Recently viewed"
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "left"
    },
    {
      "type": "range",
      "id": "max_products",
      "label": "Maximum products to track",
      "min": 4,
      "max": 20,
      "step": 1,
      "default": 12
    },
    {
      "type": "collection",
      "id": "fallback_collection",
      "label": "Fallback collection",
      "info": "Shown when the shopper has no viewing history yet. Defaults to the current product's first collection if left blank."
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "products_per_row_desktop",
      "label": "Products per row (desktop)",
      "min": 2,
      "max": 6,
      "step": 1,
      "default": 4
    },
    {
      "type": "select",
      "id": "products_per_row_mobile",
      "label": "Products per row (mobile)",
      "options": [
        {
          "value": "1",
          "label": "1"
        },
        {
          "value": "2",
          "label": "2"
        }
      ],
      "default": "2"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Gap between products",
      "min": 8,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Section padding",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "product_title_color",
      "label": "Product title",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "price_color",
      "label": "Price",
      "default": "#000000"
    },
    {
      "type": "color",
      "id": "nav_button_background",
      "label": "Navigation button background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "nav_button_color",
      "label": "Navigation button icon",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "range",
      "id": "product_title_size",
      "label": "Product title size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "price_size",
      "label": "Price size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "card_border_radius",
      "label": "Card border radius",
      "min": 0,
      "max": 24,
      "step": 2,
      "unit": "px",
      "default": 8
    }
  ],
  "presets": [
    {
      "name": "Recently viewed carousel"
    }
  ]
}
{% endschema %}