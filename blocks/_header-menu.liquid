
{%- doc -%}
  Renders a header menu block.

  @param {string} [variant] - What version of the menu to render. Defaults to header menu.
  @param {string} [transparent] - Show a transparent menu
{%- enddoc -%}

{% liquid
  assign block_settings = block.settings
  assign effective_submenu_color = block_settings.background_color | default: settings.page_background_color
%}

{% case variant %}
  {% when 'mobile' %}
    <div
      class="header__drawer"
      ref="headerDrawerContainer"
      data-hydration-key="header-drawer-mobile"
      {{ block.shopify_attributes }}
    >
      {% render 'header-drawer',
        linklist: block_settings.menu,
        data_header_drawer_type: 'mobile-drawer',
        block: block,
        section: section
      %}
    </div>

  {% when 'navigation_bar' %}
    {% if block_settings.navigation_bar == true %}
      {% render 'contrast-override',
        background_color: block_settings.background_color_navigation_bar,
        text_color: block_settings.text_color_navigation_bar,
        section_id: block.id
      %}
      <div
        class="menu-list menu-list--mobile{% if transparent == blank %} color-custom-{{ block.id }}{% endif %}"
        style="--menu-horizontal-gap: 15px; --mobile-nav-margin: auto;"
        data-hydration-key="header-menu-mobile-navigation-bar"
      >
        <div class="menu-list__scroll-container">
          <ul
            class="menu-list__list list-unstyled"
            role="list"
          >
            {% for link in block_settings.menu.links %}
              <li>
                <a
                  href="{{ link.url }}"
                  id="MenuItem-{{ link.handle }}"
                  class="menu-list__item"
                  {% if link.current %}
                    aria-current="page"
                  {% endif %}
                >
                  {{- link.title -}}
                </a>
              </li>
            {% endfor %}
          </ul>
        </div>
      </div>
    {% endif %}
  {% else %}
    {% liquid
      assign block_settings = block.settings
      assign menu_content_type = block_settings.menu_style | default: 'text'
      assign image_border_radius = block_settings.image_border_radius

      render 'contrast-override', background_color: block_settings.background_color, text_color: block_settings.text_color, section_id: block.id

      assign background_color_classes = ''
      assign background_color_setting_id = 'background_color_' | append: section.settings.menu_row
      assign current_background_color = block_settings.background_color | default: settings.page_background_color
      assign parent_background_color = section.settings[background_color_setting_id] | default: settings.page_background_color

      if parent_background_color != current_background_color or block_settings.text_color != blank
        assign background_color_classes = ' color-custom-' | append: block.id
      endif

      # Check if header and menu colors match. This is used to apply different padding styles in css
      if parent_background_color.rgb == current_background_color.rgb
        assign background_color_classes = background_color_classes | append: ' background-matches-parent'
      endif

      if block_settings.menu_style == 'featured_collections'
        assign ratio = block_settings.featured_collections_aspect_ratio
      elsif block_settings.menu_style == 'featured_products'
        assign ratio = block_settings.featured_products_aspect_ratio
      endif
    %}

    {% capture children %}
      {% for link in block_settings.menu.links %}
        {% liquid
          assign link_title_downcase = link.title | downcase
          assign link_is_badged = false
          assign link_is_gift = false
          if link_title_downcase == 'new arrival' or link_title_downcase == 'new arrivals'
            assign link_is_badged = true
          endif
          if link_title_downcase == 'gifts' or link_title_downcase == 'gift'
            assign link_is_gift = true
          endif

          # Resolve matching collections dynamically for the link
          assign has_submenu = false
          assign matched_handles_str = ""

          if link_is_badged == false and link_is_gift == false
            if link.links != blank
              assign has_submenu = true
            else
              # Map link title to search keyword
              assign keyword = ""
              if link_title_downcase contains 'painting'
                assign keyword = 'painting'
              elsif link_title_downcase contains 'decor'
                assign keyword = 'decor'
              elsif link_title_downcase contains 'art'
                assign keyword = 'art'
              elsif link_title_downcase contains 'table'
                assign keyword = 'table'
              elsif link_title_downcase contains 'mirror'
                assign keyword = 'mirror'
              elsif link_title_downcase contains 'chair'
                assign keyword = 'chair'
              elsif link_title_downcase contains 'clock'
                assign keyword = 'clock'
              elsif link_title_downcase contains 'lamp'
                assign keyword = 'lamp'
