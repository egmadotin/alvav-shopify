<div class="customer-layout">
  <div class="customer-dashboard-header">
    <div>
      <h1>Addresses</h1>
      <p style="margin: 4px 0 0 0;"><a href="{{ routes.account_url }}" style="color: #666; text-decoration: underline;">&larr; Back to Account</a></p>
    </div>
    <button type="button" class="customer-form-btn" style="width: auto; padding: 10px 20px; margin-top: 0;" onclick="toggleAddAddressForm();">
      Add New Address
    </button>
  </div>

  <!-- Add New Address Form Container -->
  <div id="AddAddressContainer" class="customer-card" style="display: none; margin-bottom: 40px; border-color: #000;">
    <h2 class="customer-card-title" style="margin-bottom: 24px;">Add a new address</h2>
    
    {%- form 'customer_address', customer.new_address, class: 'address-form' -%}
      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
        <div class="customer-form-field">
          <label for="AddressFirstNameNew">First name</label>
          <input type="text" id="AddressFirstNameNew" name="address[first_name]" value="{{ form.first_name }}" autocomplete="given-name">
        </div>
        <div class="customer-form-field">
          <label for="AddressLastNameNew">Last name</label>
          <input type="text" id="AddressLastNameNew" name="address[last_name]" value="{{ form.last_name }}" autocomplete="family-name">
        </div>
      </div>

      <div class="customer-form-field">
        <label for="AddressCompanyNew">Company</label>
        <input type="text" id="AddressCompanyNew" name="address[company]" value="{{ form.company }}" autocomplete="organization">
      </div>

      <div class="customer-form-field">
        <label for="AddressAddress1New">Address 1</label>
        <input type="text" id="AddressAddress1New" name="address[address1]" value="{{ form.address1 }}" autocomplete="address-line1" required>
      </div>

      <div class="customer-form-field">
        <label for="AddressAddress2New">Address 2</label>
        <input type="text" id="AddressAddress2New" name="address[address2]" value="{{ form.address2 }}" autocomplete="address-line2">
      </div>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
        <div class="customer-form-field">
          <label for="AddressCityNew">City</label>
          <input type="text" id="AddressCityNew" name="address[city]" value="{{ form.city }}" autocomplete="address-level2" required>
        </div>
        <div class="customer-form-field">
          <label for="AddressCountryNew">Country/Region</label>
          <select id="AddressCountryNew" name="address[country]" data-default="{{ form.country }}" autocomplete="country" required>
            {{ all_country_option_tags }}
          </select>
        </div>
      </div>

      <div id="AddressProvinceContainerNew" class="customer-form-field" style="display: none;">
        <label for="AddressProvinceNew">Province/State</label>
        <select id="AddressProvinceNew" name="address[province]" data-default="{{ form.province }}" autocomplete="address-level1"></select>
      </div>

      <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
        <div class="customer-form-field">
          <label for="AddressZipNew">Postal/Zip code</label>
          <input type="text" id="AddressZipNew" name="address[zip]" value="{{ form.zip }}" autocomplete="postal-code" required>
        </div>
        <div class="customer-form-field">
          <label for="AddressPhoneNew">Phone</label>
          <input type="text" id="AddressPhoneNew" name="address[phone]" value="{{ form.phone }}" autocomplete="tel">
        </div>
      </div>

      <div style="margin: 16px 0;">
        <label style="display: inline-flex; align-items: center; gap: 8px; font-size: 0.95rem; cursor: pointer;">
          {{ form.set_as_default_checkbox }}
          <span>Set as default address</span>
        </label>
      </div>

      <div style="display: flex; gap: 12px; margin-top: 24px;">
        <button type="submit" class="customer-form-btn" style="width: auto; padding: 12px 24px;">Add address</button>
        <button type="button" class="address-action-btn" style="padding: 12px 24px;" onclick="toggleAddAddressForm(false);">Cancel</button>
      </div>
    {%- endform -%}
  </div>

  <!-- Address List Section -->
  <div class="customer-card">
    <h2 class="customer-card-title">Address List</h2>

    {% paginate customer.addresses by 5 %}
      {% if customer.addresses.size > 0 %}
        {% for address in customer.addresses %}
          <div class="address-item">
            <h3 style="font-size: 1.1rem; font-weight: 700; margin-top: 0; margin-bottom: 8px; color: #111;">
              {{ address.first_name }} {{ address.last_name }}
              {% if address == customer.default_address %}
                <span class="address-default-badge">Default</span>
              {% endif %}
            </h3>

            <div style="color: #666; font-size: 0.95rem; line-height: 1.6;">
              {{ address.company }}<br>
              {{ address.address1 }}<br>
              {% if address.address2 != blank %}
                {{ address.address2 }}<br>
              {% endif %}
              {{ address.city }}, {{ address.province_code }} {{ address.zip }}<br>
              {{ address.country }}
              {% if address.phone != blank %}
                <br>Phone: {{ address.phone }}
              {% endif %}
            </div>

            <div class="address-actions">
              <button type="button" class="address-action-btn" onclick="toggleEditAddressForm('{{ address.id }}');">
                Edit
              </button>
              <form method="post" action="/account/addresses/{{ address.id }}" onsubmit="return confirm('Are you sure you want to delete this address?');">
                <input type="hidden" name="_method" value="delete">
                <button type="submit" class="address-action-btn address-action-btn--delete">
                  Delete
                </button>
              </form>
            </div>

            <!-- Edit Address Form Container -->
            <div id="EditAddress_{{ address.id }}" class="address-form-container" style="display: none;">
              <h4 style="font-size: 1rem; margin-top: 0; margin-bottom: 20px; font-weight: 700;">Edit address</h4>
              
              {%- form 'customer_address', address -%}
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                  <div class="customer-form-field">
                    <label for="AddressFirstName_{{ address.id }}">First name</label>
                    <input type="text" id="AddressFirstName_{{ address.id }}" name="address[first_name]" value="{{ form.first_name }}">
                  </div>
                  <div class="customer-form-field">
                    <label for="AddressLastName_{{ address.id }}">Last name</label>
                    <input type="text" id="AddressLastName_{{ address.id }}" name="address[last_name]" value="{{ form.last_name }}">
                  </div>
                </div>

                <div class="customer-form-field">
                  <label for="AddressCompany_{{ address.id }}">Company</label>
                  <input type="text" id="AddressCompany_{{ address.id }}" name="address[company]" value="{{ form.company }}">
                </div>

                <div class="customer-form-field">
                  <label for="AddressAddress1_{{ address.id }}">Address 1</label>
                  <input type="text" id="AddressAddress1_{{ address.id }}" name="address[address1]" value="{{ form.address1 }}" required>
                </div>

                <div class="customer-form-field">
                  <label for="AddressAddress2_{{ address.id }}">Address 2</label>
                  <input type="text" id="AddressAddress2_{{ address.id }}" name="address[address2]" value="{{ form.address2 }}">
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                  <div class="customer-form-field">
                    <label for="AddressCity_{{ address.id }}">City</label>
                    <input type="text" id="AddressCity_{{ address.id }}" name="address[city]" value="{{ form.city }}" required>
                  </div>
                  <div class="customer-form-field">
                    <label for="AddressCountry_{{ address.id }}">Country/Region</label>
                    <select id="AddressCountry_{{ address.id }}" name="address[country]" data-default="{{ form.country }}" data-form-id="{{ address.id }}" autocomplete="country" required>
                      {{ all_country_option_tags }}
                    </select>
                  </div>
                </div>

                <div id="AddressProvinceContainer_{{ address.id }}" class="customer-form-field" style="display: none;">
                  <label for="AddressProvince_{{ address.id }}">Province/State</label>
                  <select id="AddressProvince_{{ address.id }}" name="address[province]" data-default="{{ form.province }}" autocomplete="address-level1"></select>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 20px;">
                  <div class="customer-form-field">
                    <label for="AddressZip_{{ address.id }}">Postal/Zip code</label>
                    <input type="text" id="AddressZip_{{ address.id }}" name="address[zip]" value="{{ form.zip }}" required>
                  </div>
                  <div class="customer-form-field">
                    <label for="AddressPhone_{{ address.id }}">Phone</label>
                    <input type="text" id="AddressPhone_{{ address.id }}" name="address[phone]" value="{{ form.phone }}">
                  </div>
                </div>

                <div style="margin: 16px 0;">
                  <label style="display: inline-flex; align-items: center; gap: 8px; font-size: 0.95rem; cursor: pointer;">
                    {{ form.set_as_default_checkbox }}
                    <span>Set as default address</span>
                  </label>
                </div>

                <div style="display: flex; gap: 12px; margin-top: 24px;">
                  <button type="submit" class="customer-form-btn" style="width: auto; padding: 12px 24px;">Update address</button>
                  <button type="button" class="address-action-btn" style="padding: 12px 24px;" onclick="toggleEditAddressForm('{{ address.id }}', false);">Cancel</button>
                </div>
              {%- endform -%}
            </div>
          </div>
        {% endfor %}

        <!-- Pagination -->
        {% if paginate.pages > 1 %}
          <div style="display: flex; justify-content: center; gap: 8px; margin-top: 24px;">
            {% if paginate.previous %}
              <a href="{{ paginate.previous.url }}" style="padding: 8px 12px; border: 1px solid #ccc; border-radius: 4px; color: #000; text-decoration: none;">&laquo; Previous</a>
            {% endif %}
            {% for part in paginate.parts %}
              {% if part.is_link %}
                <a href="{{ part.url }}" style="padding: 8px 12px; border: 1px solid #ccc; border-radius: 4px; color: #000; text-decoration: none;">{{ part.title }}</a>
              {% else %}
                <span style="padding: 8px 12px; background: #eee; border: 1px solid #ccc; border-radius: 4px; font-weight: bold;">{{ part.title }}</span>
              {% endif %}
            {% endfor %}
            {% if paginate.next %}
              <a href="{{ paginate.next.url }}" style="padding: 8px 12px; border: 1px solid #ccc; border-radius: 4px; color: #000; text-decoration: none;">Next &raquo;</a>
            {% endif %}
          </div>
        {% endif %}

      {% else %}
        <p style="color: #888; text-align: center; padding: 20px;">No addresses configured.</p>
      {% endif %}
    {% endpaginate %}
  </div>
</div>

<script>
  function toggleAddAddressForm(show = true) {
    const container = document.getElementById('AddAddressContainer');
    container.style.display = show ? 'block' : 'none';
    if (show) {
      container.scrollIntoView({ behavior: 'smooth' });
    }
  }

  function toggleEditAddressForm(id, show = true) {
    const container = document.getElementById('EditAddress_' + id);
    container.style.display = show ? 'block' : 'none';
    if (show) {
      container.scrollIntoView({ behavior: 'smooth' });
    }
  }

  // Setup country province selectors
  window.addEventListener('DOMContentLoaded', () => {
    // A simple country province selector helper using Shopify's default scripts
    if (Shopify && Shopify.CountryProvinceSelector) {
      new Shopify.CountryProvinceSelector('AddressCountryNew', 'AddressProvinceNew', {
        hideElement: 'AddressProvinceContainerNew'
      });

      // Loop through existing edit forms
      document.querySelectorAll('[id^="AddressCountry_"]').forEach(select => {
        const id = select.dataset.formId;
        new Shopify.CountryProvinceSelector('AddressCountry_' + id, 'AddressProvince_' + id, {
          hideElement: 'AddressProvinceContainer_' + id
        });
      });
    }
  });
</script>
